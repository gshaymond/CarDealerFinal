<%- include('../partials/header', { title: title || 'Vehicle Details', user }) %>

<% if (!found) { %>
  <h1>Vehicle Details</h1>
  <p><%= message || 'That vehicle could not be found.' %></p>
  <p><a href="/vehicles">Back to inventory</a></p>
<% } else { %>
  <section>
    <%- include('../partials/vehicle-card', { vehicle, linkToDetails: false, showDescription: false, thumbnailUrl: images.length > 0 ? images[0].image_url : null }) %>

    <% if (notice) { %>
      <p><%= notice %></p>
    <% } %>

    <% if (images.length > 0) { %>
      <section>
        <h2>Photos</h2>
        <% images.forEach((image) => { %>
          <figure>
            <img src="<%= image.image_url %>" alt="<%= image.alt_text || `${vehicle.year} ${vehicle.make} ${vehicle.model}` %>" width="480">
          </figure>
        <% }) %>
      </section>
    <% } else { %>
      <p>No photos have been uploaded yet.</p>
    <% } %>

    <section>
      <h2>Description</h2>
      <p><%= vehicle.description || 'No description has been added yet.' %></p>
    </section>

    <section>
      <h2>Reviews</h2>

      <% if (user) { %>
        <section>
          <h3><%= currentUserReview ? 'Update your review' : 'Leave a review' %></h3>

          <% if (reviewError) { %>
            <p><%= reviewError %></p>
          <% } %>

          <form method="post" action="/vehicles/<%= vehicle.id %>/reviews">
            <label>
              Rating
              <select name="rating" required>
                <% for (let rating = 5; rating >= 1; rating -= 1) { %>
                  <option value="<%= rating %>" <%= String(reviewForm.rating || (currentUserReview && currentUserReview.rating) || '') === String(rating) ? 'selected' : '' %>><%= rating %></option>
                <% } %>
              </select>
            </label>

            <label>
              Comment
              <textarea name="comment" rows="4" required><%= reviewForm.comment || (currentUserReview && currentUserReview.comment) || '' %></textarea>
            </label>

            <button type="submit"><%= currentUserReview ? 'Update review' : 'Submit review' %></button>
          </form>

          <% if (currentUserReview) { %>
            <form method="post" action="/reviews/<%= currentUserReview.id %>/delete">
              <button type="submit">Delete my review</button>
            </form>
          <% } %>
        </section>
      <% } else { %>
        <p><a href="/auth/login">Log in</a> to leave a review.</p>
      <% } %>

      <% if (reviews.length === 0) { %>
        <p>No one has reviewed this vehicle yet.</p>
      <% } else { %>
        <% reviews.forEach((review) => { %>
          <article>
            <header>
              <strong><%= review.display_name || 'Anonymous' %></strong>
              <span aria-label="<%= review.rating %> out of 5"><%= '★'.repeat(review.rating) %><%= '☆'.repeat(5 - review.rating) %></span>
            </header>
            <p>
              <strong>Status:</strong> <%= review.status %>
              <span><%= new Date(review.created_at).toLocaleDateString() %></span>
            </p>
            <p><%= review.comment %></p>
          </article>
        <% }) %>
      <% } %>
    </section>

    <section>
      <h2>Request Service</h2>

      <% if (!user) { %>
        <p><a href="/auth/login">Log in</a> to submit a service request.</p>
      <% } else { %>
        <% if (serviceRequestError) { %>
          <p><%= serviceRequestError %></p>
        <% } %>

        <form method="post" action="/vehicles/<%= vehicle.id %>/service-requests">
          <label>
            Service type
            <select name="serviceType" required>
              <option value="">Choose a service</option>
              <% serviceTypes.forEach((serviceType) => { %>
                <option value="<%= serviceType %>" <%= (serviceRequestForm.serviceType || '') === serviceType ? 'selected' : '' %>><%= serviceType %></option>
              <% }) %>
            </select>
          </label>

          <label>
            Notes
            <textarea name="notes" rows="4" required><%= serviceRequestForm.notes || '' %></textarea>
          </label>

          <button type="submit">Submit request</button>
        </form>
      <% } %>
    </section>

    <p><a href="/vehicles">Back to inventory</a></p>
  </section>
<% } %>

<%- include('../partials/footer') %>