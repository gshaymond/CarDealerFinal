<%- include('../partials/header', { title: title || 'Inventory', user }) %>
<h1>Inventory</h1>
<p>Browse the vehicles we have available. This page is ready for database records and shows a clean empty state until inventory is added.</p>

<% if (vehicles.length === 0) { %>
  <section>
    <h2>No vehicles yet</h2>
    <p>Inventory will appear here once your database is connected and seeded.</p>
    <p><a href="/">Return home</a></p>
  </section>
<% } else { %>
  <section aria-label="Vehicle inventory">
    <% vehicles.forEach((vehicle) => { %>
      <%- include('../partials/vehicle-card', { vehicle, linkToDetails: true, showDescription: true, thumbnailUrl: vehicle.image_url }) %>
    <% }) %>
  </section>
<% } %>

<%- include('../partials/footer') %>